From ‘examples/window/window_attributes’:
     <window title="Example Window"
         icon-name="gtk-dialog-warning">
         <vbox>
             <text><label>Hello, World!</label></text>
             <hbox>
                 <button stock="ok"/>
                 <button stock="cancel"/>
             </hbox>
         </vbox>
     </window>


