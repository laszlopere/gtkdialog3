#!/bin/sh

GTKDIALOG=gtkdialog3

TMPDIR=/tmp/gtkdialog3/examples/webview
mkdir -p "$TMPDIR"

# Generate a local home page with links
cat > "$TMPDIR"/home.html << 'HTMLEOF'
<!DOCTYPE html>
<html>
<head><title>Linux News Portal</title></head>
<body style="font-family: sans-serif; margin: 2em;">
<h1>Linux News Portal</h1>
<p>Welcome to the gtkdialog3 webview demo. This page was generated locally
by the example script to demonstrate loading HTML content from a file.</p>
<h2>News Sites</h2>
<ul>
<li><a href="https://lwn.net">LWN.net</a> &mdash; Linux Weekly News, in-depth
    articles and kernel coverage</li>
<li><a href="https://phoronix.com">Phoronix</a> &mdash; Linux hardware reviews
    and benchmarks</li>
</ul>
<h2>About this widget</h2>
<p>The <code>&lt;webview&gt;</code> widget uses WebKitGTK to render HTML inside
a GTK window. It can load URLs, local HTML files, or HTML generated by shell
commands. The current URL is exported as the widget variable value when the
dialog closes.</p>
</body>
</html>
HTMLEOF

# Write the initial page path
echo "$TMPDIR/home.html" > "$TMPDIR"/nav

MAIN_DIALOG='
<window title="Linux News" width-request="900" height-request="700">
	<vbox spacing="6" border-width="8">
		<frame title="Description" space-expand="false" space-fill="false">
			<text>
				<label>This example demonstrates the webview widget by loading web pages and local
HTML content. Use the navigation buttons to switch between the generated home
page and two Linux news sites. You can also click links inside the web pages.</label>
			</text>
		</frame>
		<frame title="Browser" space-expand="true" space-fill="true">
			<hbox spacing="6" space-expand="false" space-fill="false">
				<button>
					<label>Home</label>
					<action>echo "'"$TMPDIR"'/home.html" > '"$TMPDIR"'/nav</action>
					<action>refresh:webPage</action>
				</button>
				<button>
					<label>LWN.net</label>
					<action>echo "https://lwn.net" > '"$TMPDIR"'/nav</action>
					<action>refresh:webPage</action>
				</button>
				<button>
					<label>Phoronix</label>
					<action>echo "https://phoronix.com" > '"$TMPDIR"'/nav</action>
					<action>refresh:webPage</action>
				</button>
			</hbox>
			<webview space-expand="true" space-fill="true">
				<variable>webPage</variable>
				<input type="file">'"$TMPDIR"'/nav</input>
			</webview>
		</frame>
		<buttonbox layout="end" space-expand="false" space-fill="false">
			<button stock="ok"/>
		</buttonbox>
	</vbox>
	<variable>webviewDialog</variable>
</window>
'
export MAIN_DIALOG

case $1 in
	-d | --dump) echo "$MAIN_DIALOG" ;;
	*) $GTKDIALOG --space-expand=true --space-fill=true \
		--program=MAIN_DIALOG --output-format=json ;;
esac
