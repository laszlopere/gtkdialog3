#!/bin/sh

# Progressbar example with a slow input command, suitable for testing
# that Cancel properly terminates the child process tree.

GTKDIALOG=gtkdialog3

MAIN_DIALOG="
<window title='Progressbar Cancel'>
	<vbox>
		<frame title='Progress'>
			<text>
				<label>This progress bar runs slowly to allow cancellation.</label>
			</text>
			<progressbar>
				<label>Working...</label>
				<input>for i in \$(seq 0 5 100); do echo \$i; sleep 1; done</input>
				<action function='exit'>Ready</action>
			</progressbar>
		</frame>
		<hbox>
			<button stock='cancel'/>
		</hbox>
	</vbox>
</window>
"
export MAIN_DIALOG

case $1 in
	-d | --dump) echo "$MAIN_DIALOG" ;;
	*) $GTKDIALOG --program=MAIN_DIALOG ;;
esac
