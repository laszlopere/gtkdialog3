#!/bin/sh

# Demonstrates combobox tag attributes passed as GObject properties.
#
# case-sensitive="false" - Text matching for value-in-list is
#                          case-insensitive (e.g. "first" matches "First").
# value-in-list="true"  - Restricts the entry so only values present in
#                          the dropdown list are accepted.
# allow-empty="false"   - When combined with value-in-list, prevents the
#                          user from leaving the entry empty.

GTKDIALOG=gtkdialog3

MAIN_DIALOG='
<window>
	<vbox spacing="10" border-width="10">
		<text>
			<label>"Combobox attribute demo.

The first combobox has case-sensitive and
value-in-list set: only list items are accepted.

The second adds allow-empty set to false:
the entry cannot be left blank."</label>
		</text>
		<frame title="Combobox widgets">
			<hbox homogeneous="true">
				<text space-expand="true" space-fill="true" xalign="1">
					<label>value-in-list:</label>
				</text>
				<combobox case-sensitive="false" value-in-list="true" space-expand="true" space-fill="true">
					<variable>COMBOBOX1</variable>
					<item>First</item>
					<item>Second</item>
					<item>Third</item>
				</combobox>
			</hbox>
			<hbox homogeneous="true">
				<text space-expand="true" space-fill="true" xalign="1">
					<label>allow-empty:</label>
				</text>
				<combobox allow-empty="false" value-in-list="true" space-expand="true" space-fill="true">
					<variable>COMBOBOX2</variable>
					<item>First</item>
					<item>Second</item>
					<item>Third</item>
				</combobox>
			</hbox>
		</frame>
		<hbox>
			<button stock="ok"/>
			<button stock="cancel"/>
		</hbox>
	</vbox>
</window>
'
export MAIN_DIALOG

case $1 in
	-d | --dump) echo "$MAIN_DIALOG" ;;
	*) $GTKDIALOG --program=MAIN_DIALOG ;;
esac
